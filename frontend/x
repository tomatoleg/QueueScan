// Priority-aware enqueue
function enqueueCall(file, category){

    // 🔒 HARD FILTER ENFORCEMENT
   if (
       lockEnabled &&
       !file._isReplay &&   // allow replay always
       !allowedTalkgroups.has(file._tg)
   ){
       return; // ❌ do not enqueue
   }

    // 🔒 Replay lock mode
    if (replayLock && !file._isReplay) {
      // Always push live traffic to the BACK during replay
      callQueue.push(file);
      updateQueueDisplay();
      renderQueuePreview();
      return;
      }

    if(replayLock && file._tg !== replayTargetTG){
       // 🔒 Still process normally — just don't preempt replay
       // BUT DO NOT bypass dedupe or priority logic
       file._deferred = true;   // mark as deferred (optional)
      }


    // Avoid duplicates

    // 🔥 HARD DEDUPE (queue + current + seen)
    if (
        (!file._isReplay && seenCalls.has(file.name)) ||
        isInQueue(file.name) ||
        (currentFile && currentFile.name === file.name)
    ){
        return;
    }

    // Track seen calls (live only)
    if (!file._isReplay) {
        seenCalls.add(file.name);
    }



   // optional cleanup to prevent memory growth
   if (seenCalls.size > 2000) {
       const first = seenCalls.values().next().value;
       seenCalls.delete(first);
       }
   

    // Maintain max length
    if(callQueue.length >= MAX_QUEUE){
        callQueue.shift();
    }

    // Insert based on priority
    let prio;

    // 1️⃣ Replay
    if (file._isReplay) {
        prio = 0;
    }

    // 2️⃣ TGID override
    else if (file._tgid !== undefined && talkgroupPriority[file._tgid] !== undefined) {
        prio = talkgroupPriority[file._tgid];
    }

    // 3️⃣ Category fallback
    else {
        prio = priorityOrder[category] || 99;
    }


    // ✅ IMPORTANT: assign BEFORE inserting
    file._prio = prio;

    // 🔥 REPLAY ALWAYS GOES TO FRONT
    if (file._isReplay) {
        callQueue.unshift(file);
    } else {

        let inserted = false;

        for(let i=0;i<callQueue.length;i++){
            const existing = callQueue[i];
            const existingPrio = existing._prio || 99;
    
            // 🔥 NEVER insert ahead of replay items
            if(existing._isReplay){
                continue;
            }
    
            if(prio < existingPrio){
                callQueue.splice(i,0,file);
                inserted = true;
                break;
            }
        }
    
        if(!inserted){
            callQueue.push(file);
        }
    }




    // Attach priority metadata (not strictly necessary but handy)
    file._prio = prio;

    updateQueueDisplay();
    renderQueuePreview();

    if(!isPlaying && livePlayer.paused){
        playNextInQueue();
    }
}
